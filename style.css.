:root{

--bg:#050102;
--gold:#f7d774;
--white:#fff;
--rose:#ff4d6d;
--glass:rgba(255,255,255,.08);
--shadow:0 20px 45px rgba(0,0,0,.45);

}

*{

margin:0;
padding:0;
box-sizing:border-box;

}

html,body{

width:100%;
height:100%;
overflow:hidden;
background:var(--bg);
color:var(--white);
font-family:"Poppins",sans-serif;
-webkit-tap-highlight-color:transparent;

}

body{

position:relative;
display:flex;
justify-content:center;
align-items:center;
touch-action:manipulation;

}

canvas{

position:fixed;
inset:0;
width:100%;
height:100%;
pointer-events:none;
z-index:1;

}

.background-glow{

position:fixed;
inset:0;
background:
radial-gradient(circle at top,
rgba(247,215,116,.18),
transparent 60%);
pointer-events:none;
z-index:2;

}

.screen{

position:absolute;
inset:0;
display:none;
justify-content:center;
align-items:center;
z-index:5;

}

.screen.active{

display:flex;

}

.welcome-card{

width:min(92vw,380px);
padding:34px;
border-radius:24px;
background:var(--glass);
backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);
border:1px solid rgba(255,255,255,.12);
box-shadow:var(--shadow);
text-align:center;

}

.title{

font:700 2rem "Cinzel Decorative",serif;
color:var(--gold);
margin-bottom:12px;

}

.name{

font:700 2.35rem "Cinzel",serif;
margin-bottom:14px;

}

.subtitle{

line-height:1.8;
opacity:.9;
margin-bottom:28px;

}

.gold-btn{

padding:14px 34px;
border:none;
border-radius:999px;
background:linear-gradient(135deg,#f7d774,#ffb347);
color:#222;
font-weight:700;
cursor:pointer;
transition:.3s;
box-shadow:0 10px 25px rgba(247,215,116,.35);

}

.gold-btn:hover{

transform:scale(1.05);

}

.gold-btn:active{

transform:scale(.96);

}

.countdown-number{

font:700 7rem "Cinzel Decorative",serif;
color:var(--gold);
text-shadow:0 0 25px rgba(247,215,116,.75);
animation:pulse 1s infinite;

}

@keyframes pulse{

50%{

transform:scale(1.15);

}

}
