:root{

--bg:#050102;
--gold:#f7d774;
--white:#fff;
--rose:#ff4d6d;
--glass:rgba(255,255,255,.08);
--shadow:0 20px 45px rgba(0,0,0,.45);

}

*{

margin:0;
padding:0;
box-sizing:border-box;

}

html,body{

width:100%;
height:100%;
overflow:hidden;
background:var(--bg);
color:var(--white);
font-family:"Poppins",sans-serif;
-webkit-tap-highlight-color:transparent;

}

body{

position:relative;
display:flex;
justify-content:center;
align-items:center;
touch-action:manipulation;

}

canvas{

position:fixed;
inset:0;
width:100%;
height:100%;
pointer-events:none;
z-index:1;

}

.background-glow{

position:fixed;
inset:0;
background:
radial-gradient(circle at top,
rgba(247,215,116,.18),
transparent 60%);
pointer-events:none;
z-index:2;

}

.screen{

position:absolute;
inset:0;
display:none;
justify-content:center;
align-items:center;
z-index:5;

}

.screen.active{

display:flex;

}

.welcome-card{

width:min(92vw,380px);
padding:34px;
border-radius:24px;
background:var(--glass);
backdrop-filter:blur(18px);
-webkit-backdrop-filter:blur(18px);
border:1px solid rgba(255,255,255,.12);
box-shadow:var(--shadow);
text-align:center;

}

.title{

font:700 2rem "Cinzel Decorative",serif;
color:var(--gold);
margin-bottom:12px;

}

.name{

font:700 2.35rem "Cinzel",serif;
margin-bottom:14px;

}

.subtitle{

line-height:1.8;
opacity:.9;
margin-bottom:28px;

}

.gold-btn{

padding:14px 34px;
border:none;
border-radius:999px;
background:linear-gradient(135deg,#f7d774,#ffb347);
color:#222;
font-weight:700;
cursor:pointer;
transition:.3s;
box-shadow:0 10px 25px rgba(247,215,116,.35);

}

.gold-btn:hover{

transform:scale(1.05);

}

.gold-btn:active{

transform:scale(.96);

}

.countdown-number{

font:700 7rem "Cinzel Decorative",serif;
color:var(--gold);
text-shadow:0 0 25px rgba(247,215,116,.75);
animation:pulse 1s infinite;

}

@keyframes pulse{

50%{

transform:scale(1.15);

}

}
.book{

position:relative;
width:min(92vw,380px);
aspect-ratio:3/4;
perspective:2200px;
transform-style:preserve-3d;
z-index:10;

}

.page{

position:absolute;
inset:0;
background:#fff;
border-radius:18px;
overflow:hidden;
transform-origin:left center;
transform-style:preserve-3d;
backface-visibility:hidden;
-webkit-backface-visibility:hidden;
transition:transform .8s ease;
box-shadow:0 15px 35px rgba(0,0,0,.35);
cursor:pointer;

}

.page.flipped{

transform:rotateY(-180deg);

}

.page-content{

width:100%;
height:100%;
display:flex;
flex-direction:column;
padding:18px;
background:#faf8f4;

}

.cover{

background:#1b0f14;

}

.cover-content{

position:relative;
width:100%;
height:100%;

}

.cover-image{

width:100%;
height:100%;
object-fit:cover;

}

.cover-overlay{

position:absolute;
left:0;
right:0;
bottom:0;
padding:24px;
background:linear-gradient(transparent,rgba(0,0,0,.88));
text-align:center;

}

.cover-title{

font:700 2rem "Cinzel Decorative",serif;
color:#fff;

}

.cover-subtitle{

margin-top:8px;
color:var(--gold);

}

.photo{

width:100%;
height:62%;
object-fit:cover;
border-radius:14px;
box-shadow:0 10px 22px rgba(0,0,0,.25);
animation:kenburns 12s ease-in-out infinite alternate;

}

@keyframes kenburns{

from{

transform:scale(1);

}

to{

transform:scale(1.1);

}

}

.lyrics-container{

height:38%;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:14px;
line-height:1.8;
color:#333;

}

.birthday-content{

justify-content:center;
align-items:center;
text-align:center;

}

.birthday-title{

font:700 2.2rem "Cinzel Decorative",serif;
color:var(--gold);

}

.birthday-name{

margin:16px 0;
font-size:2.4rem;
font-weight:700;
color:var(--rose);

}

.birthday-message{

max-width:90%;
line-height:1.8;
color:#444;

}

.swipe-hint{

position:absolute;
left:50%;
bottom:20px;
transform:translateX(-50%);
font-size:.9rem;
letter-spacing:1px;
color:rgba(255,255,255,.9);
z-index:20;

}

.fade-in{

animation:fadeIn .8s ease both;

}

@keyframes fadeIn{

from{

opacity:0;
transform:translateY(18px);

}

to{

opacity:1;
transform:translateY(0);

}

}

@media(max-width:768px){

.book{

width:94vw;

}

.photo{

height:58%;

}

.lyrics-container{

height:42%;
font-size:.9rem;

}

.title{

font-size:1.7rem;

}

.name{

font-size:2rem;

}

.birthday-name{

font-size:2rem;

}

}

img{

display:block;
max-width:100%;
user-select:none;
-webkit-user-drag:none;

}

button{

font-family:inherit;
outline:none;

}

::-webkit-scrollbar{

display:none;

}
