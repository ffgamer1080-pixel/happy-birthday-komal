:root{

--bg:#050102;

--gold:#f7d774;

--white:#ffffff;

--rose:#ff4d6d;

--glass:rgba(255,255,255,.08);

}

*{

margin:0;

padding:0;

box-sizing:border-box;

}

html,
body{

width:100%;

height:100%;

overflow:hidden;

font-family:"Poppins",sans-serif;

background:var(--bg);

color:var(--white);

}

body{

position:relative;

-webkit-tap-highlight-color:transparent;

touch-action:manipulation;

}

canvas{

position:fixed;

top:0;

left:0;

width:100%;

height:100%;

pointer-events:none;

z-index:1;

}

.background-glow{

position:fixed;

inset:0;

background:
radial-gradient(circle at top,
rgba(255,215,120,.18),
transparent 60%);

pointer-events:none;

z-index:2;

}

.screen{

position:absolute;

inset:0;

display:none;

justify-content:center;

align-items:center;

z-index:5;

}

.screen.active{

display:flex;

}
.welcome-card{

width:90%;

max-width:380px;

padding:35px;

border-radius:24px;

background:var(--glass);

backdrop-filter:blur(18px);

-webkit-backdrop-filter:blur(18px);

border:1px solid rgba(255,255,255,.12);

text-align:center;

box-shadow:0 15px 40px rgba(0,0,0,.45);

z-index:10;

}

.title{

font-family:"Cinzel Decorative",serif;

font-size:2rem;

color:var(--gold);

margin-bottom:12px;

}

.name{

font-family:"Cinzel",serif;

font-size:2.4rem;

margin-bottom:15px;

color:var(--white);

}

.subtitle{

font-size:1rem;

line-height:1.8;

opacity:.9;

margin-bottom:30px;

}

.gold-btn{

padding:14px 34px;

border:none;

border-radius:40px;

background:linear-gradient(135deg,#f7d774,#ffb347);

color:#222;

font-size:1rem;

font-weight:700;

cursor:pointer;

box-shadow:0 8px 25px rgba(247,215,116,.35);

transition:all .3s ease;

}

.gold-btn:hover{

transform:scale(1.05);

}

.gold-btn:active{

transform:scale(.96);

}

.countdown-number{

font-size:7rem;

font-family:"Cinzel Decorative",serif;

color:var(--gold);

text-shadow:0 0 25px rgba(247,215,116,.8);

animation:pulse 1s infinite;

}

@keyframes pulse{

0%{

transform:scale(1);

}

50%{

transform:scale(1.15);

}

100%{

transform:scale(1);

}

}
.book{

position:relative;

width:360px;

height:520px;

margin:auto;

perspective:2000px;

transform-style:preserve-3d;

display:flex;

justify-content:center;

align-items:center;

z-index:10;

}

.page{

position:absolute;

width:100%;

height:100%;

top:0;

left:0;

background:#ffffff;

border-radius:16px;

overflow:hidden;

transform-origin:left center;

transform-style:preserve-3d;

backface-visibility:hidden;

-webkit-backface-visibility:hidden;

transition:transform .8s ease;

box-shadow:0 15px 35px rgba(0,0,0,.35);

cursor:pointer;

will-change:transform;

}

.page.flipped{

transform:rotateY(-180deg);

}

.page-content{

width:100%;

height:100%;

display:flex;

flex-direction:column;

padding:18px;

background:#faf8f4;

}

.cover{

background:#1b0f14;

color:#ffffff;

display:flex;

justify-content:center;

align-items:center;

}

.cover-content{

position:relative;

width:100%;

height:100%;

overflow:hidden;

}

.cover-image{

width:100%;

height:100%;

object-fit:cover;

transition:transform .8s ease;

}

.cover:hover .cover-image{

transform:scale(1.05);

}

.cover-overlay{

position:absolute;

left:0;

right:0;

bottom:0;

padding:22px;

background:linear-gradient(transparent,rgba(0,0,0,.88));

text-align:center;

}

.cover-title{

font-family:"Cinzel Decorative",serif;

font-size:2rem;

color:#ffffff;

}

.cover-subtitle{

margin-top:10px;

font-size:1rem;

color:var(--gold);

}

.photo{

width:100%;

height:62%;

object-fit:cover;

border-radius:12px;

box-shadow:0 8px 20px rgba(0,0,0,.25);

transition:transform .6s ease;

}

.page:hover .photo{

transform:scale(1.03);

}

.lyrics-container{

width:100%;

height:38%;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

text-align:center;

padding:15px;

font-size:1rem;

line-height:1.8;

color:#333;

}

.birthday-content{

justify-content:center;

align-items:center;

text-align:center;

}

.birthday-title{

font-family:"Cinzel Decorative",serif;

font-size:2.2rem;

color:var(--gold);

margin-bottom:15px;

}

.birthday-name{

font-size:2.5rem;

color:var(--rose);

margin-bottom:18px;

font-weight:700;

}

.birthday-message{

font-size:1rem;

line-height:1.8;

color:#444;

max-width:90%;

}

.swipe-hint{

position:absolute;

left:50%;

bottom:20px;

transform:translateX(-50%);

font-size:.9rem;

color:rgba(255,255,255,.9);

letter-spacing:1px;

z-index:20;

text-align:center;

}

@media(max-width:768px){

.book{

width:92vw;

height:70vh;

}

.title{

font-size:1.7rem;

}

.name{

font-size:2rem;

}

.birthday-name{

font-size:2rem;

}

.photo{

height:58%;

}

.lyrics-container{

height:42%;

font-size:.9rem;

}

}
.page img{

user-select:none;

-webkit-user-drag:none;

pointer-events:none;

}

.fade-in{

animation:fadeIn .8s ease forwards;

}

.fade-out{

animation:fadeOut .5s ease forwards;

}

@keyframes fadeIn{

from{

opacity:0;

transform:translateY(15px);

}

to{

opacity:1;

transform:translateY(0);

}

}

@keyframes fadeOut{

from{

opacity:1;

}

to{

opacity:0;

}

}

::-webkit-scrollbar{

display:none;

}

img{

max-width:100%;

display:block;

}

button{

font-family:"Poppins",sans-serif;

outline:none;

}

audio{

display:none;

}

@media(max-width:480px){

.book{

width:95vw;

height:68vh;

}

.welcome-card{

width:92%;

padding:28px;

}

.title{

font-size:1.5rem;

}

.name{

font-size:1.8rem;

}

.cover-title{

font-size:1.5rem;

}

.cover-subtitle{

font-size:.9rem;

}

.birthday-title{

font-size:1.8rem;

}

.birthday-name{

font-size:1.7rem;

}

}
